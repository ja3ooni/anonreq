# AnonReq Environment Configuration
# Copy to .env and fill in your values
# All variables prefixed with ANONREQ_ are loaded by Pydantic Settings

# Required
ANONREQ_API_KEY=<generate-a-secure-32-char-key>
ANONREQ_VALKEY_URL=redis://valkey:6379/0
ANONREQ_PRESIDIO_URL=http://presidio-analyzer:5001

# Provider API key (OpenAI, Anthropic, etc.)
PROVIDER_API_KEY=<your-provider-api-key>
PROVIDER_BASE_URL=https://api.openai.com

# Optional admin API key for hot-reload endpoints.
# If unset, POST /v1/admin/config/rules returns 401 (D-151).
ANONREQ_ADMIN_API_KEY=

# Optional (shown with defaults)
ANONREQ_HOST=0.0.0.0
ANONREQ_PORT=8080
ANONREQ_LOG_LEVEL=INFO
ANONREQ_REQUEST_TIMEOUT_SECONDS=30
ANONREQ_POLICY_CONFIG_PATH=config/enterprise-policy.yaml
ANONREQ_DATABASE_URL=sqlite+aiosqlite:///./anonreq.db
ANONREQ_ANCHOR_SIGNING_KEY=
ANONREQ_CA_DIR=./data/ca

# Required for docker-compose observability profile
POSTGRES_USER=<set-secure-postgres-user>
POSTGRES_PASSWORD=<set-secure-postgres-password>
POSTGRES_DB=anonreq

# Required for docker-compose observability profile
MINIO_ROOT_USER=<set-secure-minio-user>
MINIO_ROOT_PASSWORD=<set-secure-minio-password>

# Optional MinIO/S3 settings (if different from above)
MINIO_ENDPOINT=localhost:9000
MINIO_SECURE=false
