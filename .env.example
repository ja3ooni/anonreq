# AnonReq Environment Configuration
# Copy to .env and fill in your values
# All variables prefixed with ANONREQ_ are loaded by Pydantic Settings

# ─── Required ────────────────────────────────────────────────────────────────
ANONREQ_API_KEY=<generate-a-secure-32-char-key>
ANONREQ_VALKEY_URL=redis://valkey:6379/0
ANONREQ_PRESIDIO_URL=http://presidio-analyzer:5001

# ─── Provider ────────────────────────────────────────────────────────────────
PROVIDER_API_KEY=<your-provider-api-key>
PROVIDER_BASE_URL=https://api.openai.com

# ─── Server ──────────────────────────────────────────────────────────────────
ANONREQ_HOST=0.0.0.0
ANONREQ_PORT=8080
ANONREQ_LOG_LEVEL=INFO
ANONREQ_REQUEST_TIMEOUT_SECONDS=30
ANONREQ_PRESIDIO_MAX_CONCURRENCY=10
ANONREQ_CACHE_TTL_SECONDS=300

# ─── Policy & Classification ────────────────────────────────────────────────
ANONREQ_POLICY_CONFIG_PATH=config/enterprise-policy.yaml
ANONREQ_ACTIVE_PRESETS=

# ─── Database ────────────────────────────────────────────────────────────────
ANONREQ_DATABASE_URL=sqlite+aiosqlite:///./anonreq.db

# ─── Audit Chain ─────────────────────────────────────────────────────────────
ANONREQ_ANCHOR_SIGNING_KEY=

# ─── Admin API ───────────────────────────────────────────────────────────────
# If unset, POST /v1/admin/config/rules returns 401 (D-151).
ANONREQ_ADMIN_API_KEY=
ANONREQ_ADMIN_ROLE=administrator

# ─── OIDC Authentication ────────────────────────────────────────────────────
# If all three are set, OIDC JWT validation is enabled for admin endpoints.
ANONREQ_OIDC_ISSUER=
ANONREQ_OIDC_AUDIENCE=
ANONREQ_OIDC_JWKS_URL=
ANONREQ_OIDC_ROLE_CLAIM=role
ANONREQ_OIDC_JWKS_CACHE_SECONDS=300

# ─── mTLS ────────────────────────────────────────────────────────────────────
ANONREQ_MTLS_ENFORCE=false
ANONREQ_MTLS_TRUSTED_PROXY_CIDRS=
ANONREQ_MTLS_FORWARD_CERT_HEADER=X-Forwarded-Client-Cert

# ─── Secret Backend ──────────────────────────────────────────────────────────
# Options: vault | volume | file
ANONREQ_SECRET_BACKEND=vault
ANONREQ_SECRET_BACKEND_PATH=anonreq/provider-api-keys
ANONREQ_SECRET_VOLUME_DIR=config/secrets
ANONREQ_SECRET_VOLUME_FILE=provider-api-keys.json

# ─── License (Appliance tier) ───────────────────────────────────────────────
ANONREQ_LICENSE_SECRET=
ANONREQ_LICENSE_KEY=

# ─── Multi-Tenant (Phase 31) ────────────────────────────────────────────────
ANONREQ_TENANTS_CONFIG_PATH=config/tenants.yaml
ANONREQ_KMS_BACKEND=local
# ANONREQ_KMS_MASTER_KEY=<base64-encoded-32-byte-key>  # optional; auto-generated if unset

# ─── Metrics Cardinality (Phase 31) ─────────────────────────────────────────
ANONREQ_METRICS_MAX_TENANTS=100

# ─── Proxy ───────────────────────────────────────────────────────────────────
ANONREQ_PROXY_MODE=proxy-only
ANONREQ_CA_DIR=./data/ca

# ─── Docker Compose: PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=<set-secure-postgres-user>
POSTGRES_PASSWORD=<set-secure-postgres-password>
POSTGRES_DB=anonreq

# ─── Docker Compose: MinIO ──────────────────────────────────────────────────
MINIO_ROOT_USER=<set-secure-minio-user>
MINIO_ROOT_PASSWORD=<set-secure-minio-password>
MINIO_ENDPOINT=localhost:9000
MINIO_SECURE=false
